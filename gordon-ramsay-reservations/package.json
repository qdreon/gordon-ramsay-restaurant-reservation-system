{
  "name": "gordon-ramsay-reservations",
  "version": "0.1.0",
  "private": true,
  "overrides": {
    "postcss": "^8.5.10"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "test:e2e": "playwright test",
    "test:e2e:local": "playwright test --config=playwright.local.config.ts",
    "test:e2e:prod": "playwright test --config=playwright.prod.config.ts",
    "test:demo": "playwright test --config=playwright.local.config.ts tests/e2e/demo.spec.ts",
    "demo:headed": "playwright test tests/e2e/grrrs-live-demo.spec.ts --headed --project=chromium --workers=1",
    "demo:record": "playwright test --config=playwright.demo.config.ts",
    "demo:debug": "playwright test tests/e2e/grrrs-live-demo.spec.ts --debug --project=chromium",
    "demo:report": "playwright show-report",
    "test:perf": "node tests/lighthouse/run-lighthouse.js",
    "test:perf:legacy": "lighthouse http://localhost:3000 --quiet --output=json --output-path=./tests/lighthouse/report.json --chrome-flags=\"--no-sandbox --headless\"",
    "test:qa": "npm run test:e2e && npm run test:e2e:prod && npm run test:perf",
    "test:notify": "node scripts/poke-booking-email.cjs"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.1.0",
    "@remixicon/react": "^4.9.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.14.0",
    "mailtrap": "^4.5.1",
    "next": "16.2.6",
    "nodemailer": "^8.0.7",
    "radix-ui": "^1.4.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.39.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25",
    "@types/nodemailer": "^6.4.23",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "lighthouse": "^13.3.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
