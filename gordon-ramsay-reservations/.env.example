# Gordon Ramsay Restaurant Reservation System - Local Environment Template
#
# Copy this file to .env.local in this same directory:
#   cp .env.example .env.local
#
# Never commit .env.local. It contains private credentials.

# -----------------------------------------------------------------------------
# App URLs
# -----------------------------------------------------------------------------
# Used by redirects and email confirmation links.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
# Get these from Supabase Dashboard > Project Settings > API.
# NEXT_PUBLIC_* values are safe for browser use, but still keep the project tidy.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-only key. Required for admin/service operations, test data setup,
# profile creation helpers, reservation locking fallbacks, CRM/menu/waitlist APIs,
# and some QA tests. DO NOT expose this in browser code.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# -----------------------------------------------------------------------------
# Email / Mailtrap
# -----------------------------------------------------------------------------
# Required if you want /api/notifications/send and /api/health email checks
# to report/send successfully. For a demo without email, the app can still run,
# but notification calls may log errors or return email service status = error.
MAILTRAP_API_TOKEN=your-mailtrap-api-token
MAILTRAP_FROM="Gordon Ramsay Restaurant <noreply@example.com>"

# Optional fallback sender used by notificationService.ts if MAILTRAP_FROM is absent.
EMAIL_FROM="Gordon Ramsay Restaurant <noreply@example.com>"

# -----------------------------------------------------------------------------
# Restaurant Metadata
# -----------------------------------------------------------------------------
# Used in booking confirmation and waitlist invite emails.
RESTAURANT_NAME=Gordon Ramsay Restaurant
RESTAURANT_ADDRESS=Gordon Ramsay Restaurant, Cebu City, Philippines

# -----------------------------------------------------------------------------
# Playwright / QA overrides
# -----------------------------------------------------------------------------
# Optional. If unset, Playwright configs auto-start local servers.
# Dev E2E default: http://localhost:3000
# Prod E2E default: http://localhost:3001
# BASE_URL=http://localhost:3000
# PLAYWRIGHT_BASE_URL=http://localhost:3001
