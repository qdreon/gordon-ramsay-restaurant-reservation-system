# Gordon Ramsay Restaurant Reservation System environment template
# Copy this file to .env.local for local development and replace placeholders.
# Never commit real credentials or secrets.

# Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase public browser/server anon configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase server-side service role key
# Keep this private. Do not expose it in browser code.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Email — sender (required for any provider)
MAILTRAP_FROM="Gordon Ramsay Restaurant <reservations@example.com>"
# EMAIL_FROM can be used as a fallback sender if MAILTRAP_FROM is not set.
EMAIL_FROM="Gordon Ramsay Restaurant <reservations@example.com>"

# Option A: SMTP (Nodemailer). If SMTP_HOST is set, it takes priority over Mailtrap API.
# Examples: smtp.gmail.com, smtp.sendgrid.net, localhost (Mailpit/MailHog)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
# Set to true for providers that require STARTTLS on port 587 (e.g. some office365 setups)
SMTP_REQUIRE_TLS=false

# Option B: Mailtrap HTTP API (official transactional send or Email Testing sandbox)
MAILTRAP_API_TOKEN=your-mailtrap-api-token
# For Mailtrap *Email Testing* (inbox only, not real delivery): set sandbox + inbox id from dashboard
MAILTRAP_USE_SANDBOX=false
MAILTRAP_INBOX_ID=

# Optional restaurant metadata
RESTAURANT_NAME="Gordon Ramsay Restaurant"
RESTAURANT_ADDRESS="Cebu City, Philippines"
